import { useState, useEffect, useMemo, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  ShoppingCart, Plus, DollarSign, TrendingUp, Search, X, ChevronRight,
  CheckCircle, XCircle, Clock, LayoutGrid, List, Minus, Trash2,
  Calendar, Package, User, CreditCard, Banknote, Smartphone, Barcode
} from 'lucide-react';
import { Modal } from '@/components/ui/Modal';
import { ConfirmModal } from '@/components/ui/ConfirmModal';
import { vendasService, produtosService, clientesService } from '@/lib/services';
import { useI18nStore } from '@/stores/i18n.store';
import toast from 'react-hot-toast';
import { format, subDays, startOfMonth } from 'date-fns';
import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, PieChart as RePieChart, Pie, Cell } from 'recharts';

type ViewMode = 'cards' | 'table';
type FilterStatus = 'todos' | 'pendente' | 'aprovado' | 'cancelado';
type FilterPeriod = 'hoje' | 'semana' | 'mes' | 'todos';

interface CartItem {
  productId: string;
  description: string;
  quantity: number;
  unitPrice: number;
  productName?: string;
}

export function VendasPage() {
  const { t } = useI18nStore();
  const [data, setData] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [modalOpen, setModalOpen] = useState(false);
  const [detailOpen, setDetailOpen] = useState(false);
  const [selectedSale, setSelectedSale] = useState<any>(null);
  const [viewMode, setViewMode] = useState<ViewMode>('cards');
  const [filterStatus, setFilterStatus] = useState<FilterStatus>('todos');
  const [filterPeriod, setFilterPeriod] = useState<FilterPeriod>('todos');
  const [search, setSearch] = useState('');
  const [selectedIds, setSelectedIds] = useState<string[]>([]);
  const [confirmOpen, setConfirmOpen] = useState(false);

  // PDV State
  const [cart, setCart] = useState<CartItem[]>([]);
  const [productSearch, setProductSearch] = useState('');
  const [productResults, setProductResults] = useState<any[]>([]);
  const [searchingProducts, setSearchingProducts] = useState(false);
  const [customerSearch, setCustomerSearch] = useState('');
  const [customerResults, setCustomerResults] = useState<any[]>([]);
  const [selectedCustomer, setSelectedCustomer] = useState<any>(null);
  const [paymentMethod, setPaymentMethod] = useState('dinheiro');
  const [discount, setDiscount] = useState(0);

  const loadData = async () => { setLoading(true); try { const r = await vendasService.list(); setData(r.data || []); } catch { toast.error(t('errorLoading')); } finally { setLoading(false); } };
  useEffect(() => { loadData(); }, []);

  const filtered = useMemo(() => {
    let d = data;
    if (filterStatus !== 'todos') d = d.filter(s => s.status === filterStatus);
    if (search) d = d.filter(s => s.number?.toLowerCase().includes(search.toLowerCase()) || s.customer?.name?.toLowerCase().includes(search.toLowerCase()));
    const now = new Date();
    if (filterPeriod === 'hoje') d = d.filter(s => format(new Date(s.createdAt), 'yyyy-MM-dd') === format(now, 'yyyy-MM-dd'));
    if (filterPeriod === 'semana') { const weekAgo = subDays(now, 7); d = d.filter(s => new Date(s.createdAt) >= weekAgo); }
    if (filterPeriod === 'mes') { const monthStart = startOfMonth(now); d = d.filter(s => new Date(s.createdAt) >= monthStart); }
    return d;
  }, [data, filterStatus, filterPeriod, search]);

  const stats = {
    total: data.length,
    pendente: data.filter(s => s.status === 'pendente').length,
    aprovado: data.filter(s => s.status === 'aprovado').length,
    cancelado: data.filter(s => s.status === 'cancelado').length,
    revenue: filtered.filter(s => s.status !== 'cancelado').reduce((sum, s) => sum + s.total, 0),
    avgTicket: filtered.filter(s => s.status !== 'cancelado').length ? filtered.filter(s => s.status !== 'cancelado').reduce((sum, s) => sum + s.total, 0) / filtered.filter(s => s.status !== 'cancelado').length : 0,
    todayRevenue: data.filter(s => format(new Date(s.createdAt), 'yyyy-MM-dd') === format(new Date(), 'yyyy-MM-dd') && s.status !== 'cancelado').reduce((sum, s) => sum + s.total, 0),
    todayCount: data.filter(s => format(new Date(s.createdAt), 'yyyy-MM-dd') === format(new Date(), 'yyyy-MM-dd')).length,
  };

  // Search products for PDV
  const searchProducts = useCallback(async (query: string) => {
    if (query.length < 1) { setProductResults([]); return; }
    setSearchingProducts(true);
    try {
      const r = await produtosService.list({ search: query, limit: 10 });
      setProductResults(r.data || []);
    } catch { setProductResults([]); }
    finally { setSearchingProducts(false); }
  }, []);

  // Search customers
  const searchCustomers = useCallback(async (query: string) => {
    if (query.length < 1) { setCustomerResults([]); return; }
    try {
      const r = await clientesService.list({ search: query, isCustomer: 'true', limit: 5 });
      setCustomerResults(r.data || []);
    } catch { setCustomerResults([]); }
  }, []);

  const addToCart = (product: any) => {
    const existing = cart.find(item => item.productId === product.id);
    if (existing) {
      setCart(cart.map(item => item.productId === product.id ? { ...item, quantity: item.quantity + 1 } : item));
    } else {
      setCart([...cart, {
        productId: product.id,
        description: product.name,
        quantity: 1,
        unitPrice: product.sellingPrice,
        productName: product.name,
      }]);
    }
    setProductSearch('');
    setProductResults([]);
  };

  const updateCartItem = (index: number, field: string, value: number) => {
    setCart(cart.map((item, i) => i === index ? { ...item, [field]: value } : item));
  };

  const removeCartItem = (index: number) => {
    setCart(cart.filter((_, i) => i !== index));
  };

  const cartTotal = cart.reduce((sum, item) => sum + item.quantity * item.unitPrice, 0);
  const finalTotal = cartTotal - discount;

  const handleSave = async () => {
    if (cart.length === 0) { toast.error('Adicione pelo menos um item'); return; }
    try {
      await vendasService.create({
        customerId: selectedCustomer?.id || undefined,
        items: cart.map(item => ({ productId: item.productId, description: item.description, quantity: item.quantity, unitPrice: item.unitPrice })),
        payments: [{ method: paymentMethod, amount: finalTotal }],
        notes: '',
        status: 'aprovado',
      } as any);
      toast.success(t('saleCreated'));
      setModalOpen(false);
      setCart([]);
      setSelectedCustomer(null);
      setDiscount(0);
      loadData();
    } catch { toast.error(t('errorSaving')); }
  };

  const handleStatus = async (id: string, status: string) => { try { await vendasService.update(id, { status } as any); toast.success(status === 'aprovado' ? t('saleApproved') : t('saleCancelled')); loadData(); } catch { toast.error(t('errorSaving')); } };

  const handleBulkApprove = async () => { try { await Promise.all(selectedIds.map(id => vendasService.update(id, { status: 'aprovado' } as any))); toast.success(`${selectedIds.length} ${t('approvedSales')}`); setSelectedIds([]); loadData(); } catch { toast.error(t('errorSaving')); } };

  const openDetail = (sale: any) => { setSelectedSale(sale); setDetailOpen(true); };
  const toggleSelect = (id: string) => setSelectedIds(p => p.includes(id) ? p.filter(x => x !== id) : [...p, id]);

  const chartData = useMemo(() => {
    const days: any[] = [];
    for (let i = 6; i >= 0; i--) { const d = subDays(new Date(), i); const key = format(d, 'dd/MM'); const daySales = filtered.filter(s => format(new Date(s.createdAt), 'dd/MM') === key && s.status !== 'cancelado'); days.push({ date: key, value: daySales.reduce((sum, s) => sum + s.total, 0) / 100, count: daySales.length }); }
    return days;
  }, [filtered]);

  const statusPie = useMemo(() => [
    { name: t('pending'), value: stats.pendente, color: '#f59e0b' },
    { name: t('approved'), value: stats.aprovado, color: '#10b981' },
    { name: t('cancelled'), value: stats.cancelado, color: '#ef4444' },
  ], [stats, t]);

  const getStatusBadge = (status: string) => ({ pendente: 'bg-amber-50 text-amber-700', aprovado: 'bg-emerald-50 text-emerald-700', cancelado: 'bg-red-50 text-red-700' }[status] || 'bg-gray-50 text-gray-600');

  return (
    <motion.div initial={{ opacity: 0, y: 8 }} animate={{ opacity: 1, y: 0 }} className="space-y-5">
      <div className="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <div className="flex items-center gap-2 mb-1"><span className="text-xs text-gray-400 font-medium">{t('sales')}</span><ChevronRight size={12} className="text-gray-400" /><span className="text-xs text-gray-600 font-semibold">{t('orders')}</span></div>
          <h1 className="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">{t('sales')}</h1>
          <div className="flex items-center gap-3 mt-2">
            <span className="text-sm text-gray-500">{stats.total} {t('orders')}</span><span className="w-1 h-1 rounded-full bg-gray-300" />
            <span className="text-sm text-amber-600 font-semibold">{stats.pendente} {t('pending')}</span><span className="w-1 h-1 rounded-full bg-gray-300" />
            <span className="text-sm text-emerald-600 font-semibold">{stats.aprovado} {t('approved')}</span><span className="w-1 h-1 rounded-full bg-gray-300" />
            <span className="text-sm text-gray-400">{t('today')}: R$ {(stats.todayRevenue / 100).toFixed(2)}</span>
          </div>
        </div>
        <div className="flex items-center gap-2">
          {selectedIds.length > 0 && (<motion.button initial={{ scale: 0 }} animate={{ scale: 1 }} onClick={handleBulkApprove} className="flex items-center gap-2 px-4 py-2.5 bg-emerald-500 text-white rounded-xl text-sm font-medium hover:bg-emerald-600 shadow-lg"><CheckCircle size={15} /> {t('approve')} ({selectedIds.length})</motion.button>)}
          <div className="flex items-center gap-0.5 p-1 rounded-xl bg-black/[0.03] dark:bg-white/[0.03] border border-white/10">
            {(['cards', 'table'] as ViewMode[]).map(m => (<button key={m} onClick={() => setViewMode(m)} className={`p-2 rounded-lg transition-all ${viewMode === m ? 'bg-white dark:bg-white/15 shadow-sm text-gray-900 dark:text-white' : 'text-gray-400'}`}>{m === 'cards' ? <LayoutGrid size={16} /> : <List size={16} />}</button>))}
          </div>
          <button onClick={() => setModalOpen(true)} className="flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-xl text-sm font-semibold hover:from-emerald-600 hover:to-teal-700 shadow-lg shadow-emerald-500/25"><Plus size={16} /> {t('newSale')}</button>
        </div>
      </div>

      <div className="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2">
        {[
          { label: t('revenue'), value: `R$ ${(stats.revenue / 100).toFixed(2)}`, icon: DollarSign, color: 'from-emerald-500 to-teal-500' },
          { label: t('avgTicket'), value: `R$ ${(stats.avgTicket / 100).toFixed(2)}`, icon: TrendingUp, color: 'from-blue-500 to-indigo-500' },
          { label: t('pending'), value: stats.pendente, icon: Clock, color: 'from-amber-500 to-orange-500', action: () => setFilterStatus('pendente') },
          { label: t('approved'), value: stats.aprovado, icon: CheckCircle, color: 'from-emerald-500 to-teal-500', action: () => setFilterStatus('aprovado') },
          { label: t('cancelled'), value: stats.cancelado, icon: XCircle, color: 'from-red-500 to-rose-500', action: () => setFilterStatus('cancelado') },
          { label: t('today'), value: stats.todayCount, icon: Calendar, color: 'from-violet-500 to-purple-500', action: () => setFilterPeriod('hoje') },
          { label: t('total'), value: stats.total, icon: ShoppingCart, color: 'from-pink-500 to-rose-500', action: () => { setFilterStatus('todos'); setFilterPeriod('todos'); } },
        ].map((s, i) => (<motion.div key={s.label} initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.04 }} onClick={s.action} className="glass-card p-3 flex items-center gap-2.5 cursor-pointer hover:scale-105 transition-transform"><div className={`p-2 rounded-xl bg-gradient-to-br ${s.color}`}><s.icon size={14} className="text-white" /></div><div><p className="text-[10px] text-gray-500">{s.label}</p><p className="text-sm font-bold text-gray-900 dark:text-white">{s.value}</p></div></motion.div>))}
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div className="glass-card p-5 lg:col-span-2"><h3 className="text-sm font-semibold text-gray-900 dark:text-white mb-3">{t('revenue')} (7 {t('days')})</h3><div className="h-48"><ResponsiveContainer width="100%" height="100%"><BarChart data={chartData}><CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" strokeOpacity={0.3} /><XAxis dataKey="date" tick={{ fontSize: 10 }} stroke="#9ca3af" /><YAxis tick={{ fontSize: 10 }} stroke="#9ca3af" /><Tooltip contentStyle={{ borderRadius: 12 }} formatter={(v: number) => `R$ ${v.toFixed(2)}`} /><Bar dataKey="value" fill="#10b981" radius={[6, 6, 0, 0]} /></BarChart></ResponsiveContainer></div></div>
        <div className="glass-card p-5"><h3 className="text-sm font-semibold text-gray-900 dark:text-white mb-3">{t('status')}</h3><div className="h-48 flex items-center justify-center"><ResponsiveContainer width="100%" height="100%"><RePieChart><Pie data={statusPie} cx="50%" cy="50%" innerRadius={40} outerRadius={70} paddingAngle={3} dataKey="value">{statusPie.map((e, i) => <Cell key={i} fill={e.color} />)}</Pie><Tooltip /></RePieChart></ResponsiveContainer></div><div className="flex justify-center gap-4 mt-1">{statusPie.map(e => <div key={e.name} className="flex items-center gap-1.5 text-[10px] text-gray-500"><div className="w-2.5 h-2.5 rounded-full" style={{ background: e.color }} />{e.name}</div>)}</div></div>
      </div>

      <div className="glass-card p-3"><div className="flex flex-wrap items-center gap-3">
        <div className="relative flex-1 min-w-[200px]"><Search size={14} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" /><input value={search} onChange={e => setSearch(e.target.value)} placeholder={t('search')} className="w-full pl-9 pr-4 py-2 rounded-xl bg-black/[0.02] dark:bg-white/[0.03] border border-white/10 text-sm" />{search && <button onClick={() => setSearch('')} className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400"><X size={14} /></button>}</div>
        <div className="flex items-center gap-1 p-0.5 rounded-xl bg-black/[0.02] dark:bg-white/[0.02]">
          {[{ label: t('all'), value: 'todos' as FilterStatus }, { label: t('pending'), value: 'pendente' }, { label: t('approved'), value: 'aprovado' }, { label: t('cancelled'), value: 'cancelado' }].map(f => (<button key={f.value} onClick={() => setFilterStatus(f.value)} className={`px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${filterStatus === f.value ? 'bg-white dark:bg-white/15 shadow-sm text-gray-900 dark:text-white' : 'text-gray-500'}`}>{f.label}</button>))}
        </div>
        <select value={filterPeriod} onChange={e => setFilterPeriod(e.target.value as FilterPeriod)} className="text-xs px-3 py-2 rounded-xl bg-black/[0.02] dark:bg-white/[0.02] border border-white/10"><option value="todos">{t('all')}</option><option value="hoje">{t('today')}</option><option value="semana">{t('week')}</option><option value="mes">{t('month')}</option></select>
        <span className="ml-auto text-xs text-gray-400">{filtered.length} {t('sales')}</span>
      </div></div>

      <AnimatePresence mode="wait">
        {viewMode === 'cards' && (<motion.div key="cards" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <AnimatePresence>{filtered.slice(0, 30).map((item, i) => (<motion.div key={item.id} layout initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} exit={{ opacity: 0, scale: 0.9 }} transition={{ delay: i * 0.02 }} onClick={() => openDetail(item)} className={`glass-card p-5 cursor-pointer group ${selectedIds.includes(item.id) ? 'ring-2 ring-blue-500' : ''}`}>
            <div className="absolute top-3 left-3 opacity-0 group-hover:opacity-100 transition-opacity z-10" onClick={e => e.stopPropagation()}><input type="checkbox" checked={selectedIds.includes(item.id)} onChange={() => toggleSelect(item.id)} className="w-4 h-4 rounded border-gray-300 text-blue-500 cursor-pointer" /></div>
            <div className="flex items-start justify-between mb-3"><div><p className="text-xs font-mono font-semibold text-blue-600">{item.number}</p><p className="text-[11px] text-gray-400 mt-0.5">{item.customer?.name || t('casual')}</p></div><span className={`text-xs px-2.5 py-1 rounded-full font-semibold ${getStatusBadge(item.status)}`}>{item.status}</span></div>
            <div className="grid grid-cols-2 gap-2 mb-3"><div className="glass-card p-2.5 text-center"><p className="text-[10px] text-gray-400 mb-0.5">{t('total').toUpperCase()}</p><p className="text-base font-bold text-emerald-600">R$ {(item.total / 100).toFixed(2)}</p></div><div className="glass-card p-2.5 text-center"><p className="text-[10px] text-gray-400 mb-0.5">{t('items').toUpperCase()}</p><p className="text-base font-bold">{item.items?.length || 0}</p></div></div>
            <div className="mt-3 pt-3 border-t border-white/10 flex items-center justify-between text-[10px] text-gray-400"><span>{new Date(item.createdAt).toLocaleDateString()}</span>{item.status === 'pendente' && <button onClick={e => { e.stopPropagation(); handleStatus(item.id, 'aprovado'); }} className="text-emerald-500 font-medium">{t('approve')}</button>}</div>
          </motion.div>))}</AnimatePresence>
        </motion.div>)}
        {viewMode === 'table' && (<motion.div key="table" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="glass-card overflow-hidden"><div className="overflow-x-auto"><table className="w-full"><thead><tr className="border-b border-white/10 bg-black/[0.01]"><th className="w-10 px-4 py-3"></th><th className="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">{t('orders')}</th><th className="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase hidden md:table-cell">{t('customer')}</th><th className="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase">{t('total')}</th><th className="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase">{t('status')}</th></tr></thead><tbody>{filtered.map(item => (<tr key={item.id} onClick={() => openDetail(item)} className="border-b border-white/5 hover:bg-black/[0.02] cursor-pointer"><td className="px-4 py-3" onClick={e => e.stopPropagation()}><input type="checkbox" checked={selectedIds.includes(item.id)} onChange={() => toggleSelect(item.id)} className="w-4 h-4 rounded border-gray-300 text-blue-500 cursor-pointer" /></td><td className="px-4 py-3"><p className="text-sm font-mono font-semibold text-blue-600">{item.number}</p></td><td className="px-4 py-3 hidden md:table-cell"><p className="text-xs text-gray-500">{item.customer?.name || '—'}</p></td><td className="px-4 py-3 text-right"><p className="text-sm font-bold">R$ {(item.total / 100).toFixed(2)}</p></td><td className="px-4 py-3 text-center"><span className={`text-xs px-2.5 py-1 rounded-full font-semibold ${getStatusBadge(item.status)}`}>{item.status}</span></td></tr>))}</tbody></table></div></motion.div>)}
      </AnimatePresence>

      {/* PDV Modal */}
      <Modal open={modalOpen} onClose={() => { setModalOpen(false); setCart([]); setSelectedCustomer(null); setDiscount(0); }} title={`${t('newSale')} (${t('pdv')})`} size="lg">
        <div className="flex gap-4">
          {/* Product Search & Cart */}
          <div className="flex-1 space-y-3">
            {/* Product Search */}
            <div className="relative">
              <Search size={15} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" />
              <input
                value={productSearch}
                onChange={e => { setProductSearch(e.target.value); searchProducts(e.target.value); }}
                placeholder="Buscar produto por nome ou código..."
                className="w-full pl-10 pr-4 py-2.5 rounded-xl bg-black/[0.02] dark:bg-white/[0.03] border border-white/10 text-sm"
                autoFocus
              />
              {searchingProducts && <div className="absolute right-3 top-1/2 -translate-y-1/2"><div className="animate-spin w-4 h-4 border-2 border-blue-500 border-t-transparent rounded-full" /></div>}
              {productResults.length > 0 && (
                <div className="absolute top-full left-0 right-0 mt-1 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-white/10 z-20 max-h-48 overflow-y-auto">
                  {productResults.map((p: any) => (
                    <button key={p.id} onClick={() => addToCart(p)} className="w-full text-left px-4 py-3 hover:bg-black/[0.02] flex items-center justify-between text-sm border-b border-white/5 last:border-0">
                      <div><span className="font-medium text-gray-900 dark:text-white">{p.name}</span><span className="text-xs text-gray-400 ml-2 font-mono">{p.code}</span></div>
                      <span className="font-semibold text-emerald-600 text-xs">R$ {(p.sellingPrice / 100).toFixed(2)}</span>
                    </button>
                  ))}
                </div>
              )}
            </div>

            {/* Cart Items */}
            <div className="space-y-2 max-h-64 overflow-y-auto">
              {cart.map((item, i) => (
                <div key={i} className="flex items-center gap-3 p-3 rounded-xl bg-black/[0.01] dark:bg-white/[0.02]">
                  <div className="flex-1">
                    <p className="text-sm font-medium text-gray-900 dark:text-white">{item.productName || item.description}</p>
                    <div className="flex items-center gap-2 mt-1">
                      <button onClick={() => updateCartItem(i, 'quantity', Math.max(1, item.quantity - 1))} className="p-0.5 rounded bg-black/5 hover:bg-black/10"><Minus size={12} /></button>
                      <span className="text-sm font-bold w-6 text-center">{item.quantity}</span>
                      <button onClick={() => updateCartItem(i, 'quantity', item.quantity + 1)} className="p-0.5 rounded bg-black/5 hover:bg-black/10"><Plus size={12} /></button>
                    </div>
                  </div>
                  <div className="text-right">
                    <p className="text-sm font-bold text-emerald-600">R$ {((item.quantity * item.unitPrice) / 100).toFixed(2)}</p>
                    <p className="text-[10px] text-gray-400">R$ {(item.unitPrice / 100).toFixed(2)} un</p>
                  </div>
                  <button onClick={() => removeCartItem(i)} className="p-1 rounded-lg hover:bg-red-50 text-gray-400 hover:text-red-500"><Trash2 size={14} /></button>
                </div>
              ))}
              {cart.length === 0 && <p className="text-xs text-gray-400 text-center py-6">Busque e adicione produtos ao carrinho</p>}
            </div>
          </div>

          {/* Sidebar: Customer + Payment */}
          <div className="w-56 space-y-3 shrink-0">
            {/* Customer */}
            <div className="relative">
              <label className="text-[10px] font-semibold text-gray-500 uppercase mb-1 block">{t('customer')}</label>
              <input value={customerSearch} onChange={e => { setCustomerSearch(e.target.value); searchCustomers(e.target.value); }} placeholder="Buscar..." className="w-full px-3 py-2 rounded-xl bg-black/[0.02] border border-white/10 text-xs" />
              {selectedCustomer && <p className="text-xs text-emerald-600 mt-1 font-medium">✓ {selectedCustomer.name}</p>}
              {customerResults.length > 0 && !selectedCustomer && (
                <div className="absolute top-full left-0 right-0 mt-1 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-white/10 z-20 max-h-32 overflow-y-auto">
                  {customerResults.map((c: any) => (
                    <button key={c.id} onClick={() => { setSelectedCustomer(c); setCustomerSearch(c.name); setCustomerResults([]); }} className="w-full text-left px-3 py-2 hover:bg-black/[0.02] text-xs">{c.name}</button>
                  ))}
                </div>
              )}
            </div>

            {/* Payment */}
            <div>
              <label className="text-[10px] font-semibold text-gray-500 uppercase mb-1 block">{t('method')}</label>
              <div className="space-y-1">
                {[
                  { value: 'dinheiro', label: t('cash'), icon: Banknote },
                  { value: 'pix', label: t('pix'), icon: Smartphone },
                  { value: 'cartao_credito', label: t('card'), icon: CreditCard },
                ].map(m => (
                  <button key={m.value} onClick={() => setPaymentMethod(m.value)} className={`w-full flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium transition-all ${paymentMethod === m.value ? 'bg-emerald-500/10 text-emerald-600 ring-1 ring-emerald-500/30' : 'hover:bg-black/[0.02] text-gray-600'}`}><m.icon size={14} />{m.label}</button>
                ))}
              </div>
            </div>

            {/* Discount */}
            <div>
              <label className="text-[10px] font-semibold text-gray-500 uppercase mb-1 block">Desconto</label>
              <input type="number" value={discount} onChange={e => setDiscount(+e.target.value)} className="w-full px-3 py-2 rounded-xl bg-black/[0.02] border border-white/10 text-xs" placeholder="R$ 0,00" />
            </div>

            {/* Total */}
            <div className="glass-card p-3 text-center">
              <p className="text-[10px] text-gray-500 mb-1">{t('total').toUpperCase()}</p>
              {discount > 0 && <p className="text-xs text-gray-400 line-through">R$ {(cartTotal / 100).toFixed(2)}</p>}
              <p className="text-xl font-bold text-emerald-600">R$ {(finalTotal / 100).toFixed(2)}</p>
              <p className="text-[10px] text-gray-400">{cart.length} {t('items').toLowerCase()}</p>
            </div>

            <button onClick={handleSave} disabled={cart.length === 0}
              className="btn-primary w-full justify-center text-sm py-3 disabled:opacity-50 disabled:cursor-not-allowed">
              {t('finish')}
            </button>
          </div>
        </div>
      </Modal>

      {/* Detail Modal */}
      <Modal open={detailOpen} onClose={() => setDetailOpen(false)} title={selectedSale ? `${t('orders')} ${selectedSale.number}` : ''} size="lg">
        {selectedSale && (<div className="space-y-5">
          <div className="flex items-start justify-between"><div><p className="text-xs text-gray-400 font-mono">{selectedSale.number}</p><h2 className="text-lg font-bold mt-1">{selectedSale.customer?.name || t('casual')}</h2></div><span className={`px-3 py-1.5 rounded-full text-xs font-semibold ${getStatusBadge(selectedSale.status)}`}>{selectedSale.status}</span></div>
          <div className="grid grid-cols-3 gap-3">
            <div className="glass-card p-3"><p className="text-[11px] text-gray-500">{t('total')}</p><p className="text-lg font-bold text-emerald-600">R$ {(selectedSale.total / 100).toFixed(2)}</p></div>
            <div className="glass-card p-3"><p className="text-[11px] text-gray-500">{t('items')}</p><p className="text-lg font-bold">{selectedSale.items?.length || 0}</p></div>
            <div className="glass-card p-3"><p className="text-[11px] text-gray-500">{t('payment')}</p><p className="text-sm font-semibold capitalize">{selectedSale.payments?.[0]?.method?.replace('_', ' ') || '—'}</p></div>
          </div>
          <div><h4 className="text-xs font-semibold text-gray-500 uppercase mb-2">{t('items')}</h4><div className="space-y-1">{selectedSale.items?.map((item: any) => (<div key={item.id} className="flex items-center justify-between p-3 rounded-xl bg-black/[0.01] text-sm"><span>{item.product?.name || item.description} × {item.quantity}</span><span className="font-semibold text-emerald-600">R$ {(item.total / 100).toFixed(2)}</span></div>))}</div></div>
          {selectedSale.status === 'pendente' && (<div className="flex gap-2"><button onClick={() => { handleStatus(selectedSale.id, 'aprovado'); setDetailOpen(false); }} className="btn-primary flex-1 py-3 bg-emerald-500">✓ {t('approve')}</button><button onClick={() => { handleStatus(selectedSale.id, 'cancelado'); setDetailOpen(false); }} className="flex-1 px-4 py-3 rounded-2xl border border-red-500/30 bg-red-500/5 text-red-600 text-sm font-semibold">✕ {t('cancel')}</button></div>)}
        </div>)}
      </Modal>
    </motion.div>
  );
}