# ──── Ferramenta ERP - Variáveis de Ambiente ────

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:admin@localhost:5432/ferramenta?schema=public"

# Backend
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="ferramenta-secret-key-change-in-production"
JWT_EXPIRATION="15m"
REFRESH_TOKEN_EXPIRATION="7d"

# CORS
CORS_ORIGIN="http://localhost:1420,http://localhost:5173"